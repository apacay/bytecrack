    <!-- How to play -->
    <string name="how_to_play_title">// HOW TO PLAY</string>
    <string name="how_to_play_page">"%s (%d/%d)"</string>
    <string name="how_to_play_objective">Objective: guess the secret 3-digit code before time or attempts run out.</string>
    <string name="how_to_play_cracked_title">CRACKED</string>
    <string name="how_to_play_cracked_desc">Digits in the correct position. If you enter 1 2 3 and the code has a 2 in the second position, CRACKED will show 1.</string>
    <string name="how_to_play_found_title">FOUND</string>
    <string name="how_to_play_found_desc">Digits that are in the code but in a different position. If you enter 1 2 3 and the code has a 2 elsewhere, FOUND will show 1.</string>
    <string name="how_to_play_hints_title">HINTS (Traces)</string>
    <string name="how_to_play_hints_1">• Earn TRACES by watching ads (every 3 completed levels).</string>
    <string name="how_to_play_hints_2">• 1 TRACE = Hint: reveals a digit that\'s in the solution (without indicating its position).</string>
    <string name="how_to_play_hints_3">• 3 TRACES = Crack: reveals the exact digit at a specific position. Tap an empty slot to crack that position.</string>
    <string name="how_to_play_exec_title">EXEC</string>
    <string name="how_to_play_exec_desc">Press EXEC to submit your guess. The system will return CRACKED and FOUND based on your combination.</string>
    <string name="how_to_play_page2_intro">Every 10 completed levels, higher difficulty modes are offered:</string>
    <string name="how_to_play_hard_title">HARD MODE (4 digits)</string>
    <string name="how_to_play_hard_desc">4 decimal digits · 5,040 combinations · Points ×5 · Time bonus ×4. High risk, high reward.</string>
    <string name="how_to_play_ironman_title">IRONMAN (4 hex digits)</string>
    <string name="how_to_play_ironman_desc">4 hexadecimal digits (0-9, A-F) · 43,680 combinations · Points ×20 · Time bonus ×10. Ultimate challenge.</string>
    <string name="how_to_play_difficulty_choice">You can choose to increase difficulty or keep the current mode at every multiple of 10.</string>

