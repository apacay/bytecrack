    <!-- Cómo jugar -->
    <string name="how_to_play_title">// CÓMO JUGAR</string>
    <string name="how_to_play_page">"%s (%d/%d)"</string>
    <string name="how_to_play_objective">Objetivo: adivina el código secreto de 3 dígitos antes de que se acabe el tiempo o los intentos.</string>
    <string name="how_to_play_cracked_title">CRACKED</string>
    <string name="how_to_play_cracked_desc">Dígitos en la posición correcta. Si introduces 1 2 3 y el código tiene un 2 en la segunda posición, CRACKED mostrará 1.</string>
    <string name="how_to_play_found_title">FOUND</string>
    <string name="how_to_play_found_desc">Dígitos que están en el código pero en otra posición. Si introduces 1 2 3 y el código tiene un 2 en otra posición, FOUND mostrará 1.</string>
    <string name="how_to_play_hints_title">HINTS (Traces)</string>
    <string name="how_to_play_hints_1">• Obtienes TRACES viendo anuncios (cada 3 niveles completados).</string>
    <string name="how_to_play_hints_2">• 1 TRACE = Hint: revela un dígito que está en la solución (sin indicar en qué posición).</string>
    <string name="how_to_play_hints_3">• 3 TRACES = Crack: revela el dígito exacto en una posición concreta. Toca un slot vacío para crackear esa posición.</string>
    <string name="how_to_play_exec_title">EXEC</string>
    <string name="how_to_play_exec_desc">Pulsa EXEC para enviar tu intento. El sistema te devolverá CRACKED y FOUND según tu combinación.</string>
    <string name="how_to_play_page2_intro">Cada 10 niveles completados se ofrecen modos de mayor dificultad:</string>
    <string name="how_to_play_hard_title">HARD MODE (4 dígitos)</string>
    <string name="how_to_play_hard_desc">4 dígitos decimales · 5.040 combinaciones · Puntos ×5 · Bonus de tiempo ×4. High risk, high reward.</string>
    <string name="how_to_play_ironman_title">IRONMAN (4 dígitos hex)</string>
    <string name="how_to_play_ironman_desc">4 dígitos hexadecimales (0-9, A-F) · 43.680 combinaciones · Puntos ×20 · Bonus de tiempo ×10. Máximo desafío.</string>
    <string name="how_to_play_difficulty_choice">Puedes elegir subir de dificultad o mantener el modo actual en cada nivel múltiplo de 10.</string>

